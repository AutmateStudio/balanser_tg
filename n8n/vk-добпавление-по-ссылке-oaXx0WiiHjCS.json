        "jsCode": "const apiBase = 'http://217.26.26.32:8000';\nconst apiKey = 'ПОДСТАВЬТЕ_API_KEY_ИЗ_ENV';\nconst wallPostsCount = 20;\n\nconst input = items[0].json || {};\nconst target = (input.query && input.query.target)\n  || (input.body && input.body.target)\n  || input.target\n  || '';\n\nreturn [{ json: { apiBase, apiKey, wallPostsCount, target } }];"
      },
