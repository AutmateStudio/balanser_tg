      "parameters": {
        "jsCode": "const init = $('Init').first().json;\nconst resolve = $('Resolve').first().json || {};\nconst score = items[0].json || {};\n\n// Объединяем metadata и score\nconst combinedMetadata = {\n    ...resolve.metadata, // старые данные из metadata\n    ...score // все поля из score\n};\n\nreturn [{ \n    json: {\n        target: init.target,\n        vk_id: resolve.vk_id,\n        vk_object_type: resolve.vk_object_type,\n        resolved_via: resolve.resolved_via,\n        screen_name_fragment: resolve.screen_name_fragment,\n        is_closed: resolve.is_closed,\n        is_closed_label: resolve.is_closed_label,\n        name: resolve.name,\n        members_count: resolve.members_count,\n        deactivated: resolve.deactivated,\n        closed_check_error: resolve.closed_check_error,\n        metadata: combinedMetadata, // теперь тут и metadata и score вместе\n        // убираем дублирующиеся поля из score, т.к. они уже в metadata\n    }\n}];"
      },
