    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst groupIds = new Set();\n\nfunction addOwnerId(value) {\n  const id = Number(value);\n  if (Number.isFinite(id) && id < 0) {\n    groupIds.add(id);\n  }\n}\n\nfunction walk(node) {\n  if (!Array.isArray(node)) return;\n\n  // Пара [owner_id, post_id]\n  if (\n    node.length === 2 &&\n    (typeof node[0] === 'number' || typeof node[0] === 'string') &&\n    (typeof node[1] === 'number' || typeof node[1] === 'string')\n  ) {\n    addOwnerId(node[0]);\n    return;\n  }\n\n  // Вложенные массивы\n  for (const part of node) {\n    walk(part);\n  }\n}\n\nfor (const item of items) {\n  walk(item.json.watched_posts);\n}\n\nconst uniqueGroupIds = [...groupIds].sort((a, b) => a - b);\n\nreturn [\n  {\n    json: {\n      unique_group_ids: uniqueGroupIds,\n      count: uniqueGroupIds.length,\n    },\n  },\n];"
      },
