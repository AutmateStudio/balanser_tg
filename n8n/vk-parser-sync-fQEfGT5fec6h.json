    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nfunction toGroupId(value) {\n  const n = Number(String(value).trim());\n  return Number.isFinite(n) && n < 0 ? n : null;\n}\n\nconst watchedSet = new Set(\n  (item.unique_group_ids || []).map(toGroupId).filter((id) => id !== null)\n);\n\nconst channelsSet = new Set(\n  (item.external_channel_id || []).map(toGroupId).filter((id) => id !== null)\n);\n\nconst to_add = [...channelsSet]\n  .filter((id) => !watchedSet.has(id))\n  .sort((a, b) => a - b);\n\nconst to_remove = [...watchedSet]\n  .filter((id) => !channelsSet.has(id))\n  .sort((a, b) => a - b);\n\nreturn [\n  {\n    json: {\n      to_add,\n      to_remove,\n      to_add_count: to_add.length,\n      to_remove_count: to_remove.length,\n      watched_count: watchedSet.size,\n      channels_count: channelsSet.size,\n      walls_add_body: {\n        owner_ids: to_add,\n        count: 10,\n      },\n      walls_remove_body: {\n        owner_ids: to_remove,\n      },\n    },\n  },\n];"
      },
