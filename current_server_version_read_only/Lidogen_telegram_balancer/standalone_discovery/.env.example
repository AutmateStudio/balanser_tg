API_ID=31855433
API_HASH=941f5212e76bfd3fd77b50fd8ff3fb79
API_KEY=changeme
WEBHOOK_API_KEY=changeme
START_WEBHOOK_URL=https://example.com/telegram/start
DISCOVERY_MIN_CHANNEL_SCORE_RATIO=0.5
MAX_CHANNELS_PER_SESSION=500

# D8 — async add-channels → PostgreSQL task_queue (вместо SQLite action_queue).
# Для D12 staging: true + QUEUE_DATABASE_URL + image Dockerfile.pg-queue.
USE_PG_QUEUE=false

# DSN очереди (Tailscale → vps-100). Тот же DSN на vps-101 queue-worker.
# В network_mode: service:vpn используйте Tailscale IP vps-100 (имя не резолвится).
# QUEUE_DATABASE_URL=postgresql://lead_monitor_owner:PASSWORD@vps-100:5432/lead_monitor

# D12 Вариант A — крутить queue-worker в процессе discovery (общий in-memory clump).
# Требует USE_PG_QUEUE=true и WORKER_TASK_ADAPTER=clump; отдельный worker тогда не нужен.
# DISCOVERY_INPROCESS_WORKER=false
# WORKER_TASK_ADAPTER=clump
