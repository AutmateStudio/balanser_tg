# =============================================================================
# D12 — Discovery API + VPN
#
# КУДА:  ~/Lidogen_telegram_balancer/standalone_discovery/.env
# КАК:   cp config/d12/env.discovery-api.example standalone_discovery/.env
#
# Для чего: docker compose up -d в каталоге standalone_discovery/
# Образ:   docker build -f standalone_discovery/Dockerfile.pg-queue \
#            -t standalone-discovery-api:latest .   (из корня репо, один раз)
# =============================================================================

API_ID=31855433
API_HASH=941f5212e76bfd3fd77b50fd8ff3fb79

API_KEY=YvQgk2eS-aOf3LQP-mdSMSDJGuhV6QZU4oW82z0k3-E

WEBHOOK_API_KEY=9KGYGWDnwt3rVuBjnn_-MWrXlJKwHJnfw5Es0jAwjHc
START_WEBHOOK_URL=https://httpbin.org/post

DISCOVERY_MIN_CHANNEL_SCORE_RATIO=0.5
MAX_CHANNELS_PER_SESSION=500

USE_PG_QUEUE=true
# В network_mode: service:vpn имя vps-100 не резолвится (MagicDNS вне VPN namespace) —
# используйте Tailscale IP vps-100 (напр. 100.105.75.79). newpass123 — dev-пароль.
QUEUE_DATABASE_URL=postgresql://lead_monitor_owner:newpass123@vps-100:5432/lead_monitor

DISCOVERY_APP_PORT=8100

# D12 Вариант A — in-process queue-worker в процессе discovery (общий in-memory clump).
# Убирает конфликт Telegram-сессий и даёт discovery API видеть результат add-channels.
# При true отдельный контейнер queue-worker не нужен (docker compose stop queue-worker).
DISCOVERY_INPROCESS_WORKER=true
WORKER_TASK_ADAPTER=clump
