# Шаблон для D9 E2E — скопировать: cp env.d9.example env.d9

QUEUE_DATABASE_URL=postgresql://lead_monitor_owner:PASSWORD@vps-100:5432/lead_monitor

DISCOVERY_BASE_URL=http://194.156.117.160:8100
DISCOVERY_API_KEY=your_api_key_from_discovery_env

# USE_PG_QUEUE=true на discovery (как для D8)
PARSER_ID=your_running_parser_id

# Канал, который уже есть в clump и будет удалён через PG-очередь
E2E_CHANNEL_REF=@channel_to_remove

E2E_POLL_INTERVAL_SECONDS=2
E2E_POLL_TIMEOUT_SECONDS=180
E2E_SKIP_VERIFY_PG=false
E2E_VERIFY_TASK_ATTEMPTS=false
