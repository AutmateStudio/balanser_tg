# Шаблон для D12 E2E — скопировать: cp env.d12.example env.d12
# Не коммитить env.d12 с реальными секретами.

# --- PostgreSQL (воркер vps-101 + preflight + PG-verify) ---
QUEUE_DATABASE_URL=postgresql://lead_monitor_owner:PASSWORD@vps-100:5432/lead_monitor

# --- Discovery API (staging, Telethon + VPN) ---
DISCOVERY_BASE_URL=http://194.156.117.160:8100
DISCOVERY_API_KEY=your_api_key_from_discovery_env

# D8 на discovery (.env): USE_PG_QUEUE=true + тот же QUEUE_DATABASE_URL
# Сборка: docker build -f standalone_discovery/Dockerfile.pg-queue -t standalone-discovery-api:latest .

# Уже запущенный parser_id (рекомендуется). Если пусто — скрипт вызовет /parser/start.
PARSER_ID=

# Канал для add-channels через PG (публичный, не уже в clump, не в активной dedup-задаче).
E2E_CHANNEL_REF=@your_test_channel

# Параметры /parser/start (если PARSER_ID не задан)
E2E_SESSION_NAME=/app/sessions/Client1
E2E_START_CHANNELS=@existing_channel_in_clump
E2E_WEBHOOK_URL=https://your-n8n.example.com/webhook/telegram-test

# Ожидание воркера (queue-worker: WORKER_TASK_ADAPTER=clump)
E2E_POLL_INTERVAL_SECONDS=2
E2E_POLL_TIMEOUT_SECONDS=180

# PG-verify после успеха (task_queue, D5 usage, D7 source_channels)
E2E_SKIP_VERIFY_PG=false

# B9: проверять строки в task_attempts (только если воркер пишет историю).
# По умолчанию false — repo B9 готов, dispatch может ещё не вызывать insert/finish.
E2E_VERIFY_TASK_ATTEMPTS=false

# Для preflight на vps-101 (опционально, если гоняете с хоста)
# WORKER_TASK_ADAPTER=clump
