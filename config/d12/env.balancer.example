# =============================================================================
# D12 — balancer (корень репозитория)
#
# КУДА:  ~/Lidogen_telegram_balancer/.env
# КАК:   cp config/d12/env.balancer.example .env
#
# Для чего: migrate, sync_accounts_to_pg, queue-worker, docker test
# Сервер:  Lidogen-pg-worker-dev (vps-101), БД на vps-100 через Tailscale
# =============================================================================

DATABASE_URL=postgresql://lead_monitor_owner:newpass123@vps-100:5432/lead_monitor
QUEUE_DATABASE_URL=postgresql://lead_monitor_owner:newpass123@vps-100:5432/lead_monitor

MIGRATE_MODE=auto
PYTEST_TEST_PRIORITY=2000000000

LOG_LEVEL=INFO
WORKER_TASK_ADAPTER=clump

WORKER_ID=
WORKER_TASK_TYPES=

WORKER_POLL_INTERVAL_SECONDS=1.0
WORKER_LOCK_TTL_SECONDS=300
WORKER_RETRY_DELAY_SECONDS=60
WORKER_POSTPONE_DELAY_SECONDS=300
WORKER_WATCHDOG_ENABLED=true
WORKER_WATCHDOG_INTERVAL_SECONDS=30

# G5 — auto-retry зависших задач (default off в prod; см. docs/queue-runbook.md §G5)
WATCHDOG_AUTO_RETRY_ENABLED=false
WATCHDOG_AUTO_RETRY_MAX_ATTEMPTS=2
WATCHDOG_AUTO_RETRY_DELAY_SECONDS=60

# G4/G6/G7 — мониторинг (profile monitoring; см. docs/queue-runbook.md)
MONITOR_INTERVAL_SECONDS=120
ALERT_ENABLED=true
ALERT_WEBHOOK_URL=
ALERT_COOLDOWN_SECONDS=1800
ERROR_DETECTOR_ENABLED=true
ERROR_DETECTOR_WINDOW_SECONDS=3600
ERROR_DETECTOR_MIN_COUNT=5
ERROR_DETECTOR_RPH_FACTOR=0.7
ERROR_DETECTOR_MIN_RPH=2
ERROR_DETECTOR_REPEAT_WINDOW_SECONDS=86400
ERROR_DETECTOR_COOLDOWN_SECONDS=3600
DEV_ALERT_TELEGRAM_CHAT_ID=
BOT_TOKEN=

HOST_SESSIONS_DIR=./standalone_discovery/sessions

ACCOUNT_STORE_PATH=standalone_discovery/discovery_api/data/telegram_accounts.db
PARSER_STORE_PATH=standalone_discovery/discovery_api/data/parser_jobs.json
SESSIONS_DIR=standalone_discovery/sessions

API_ID=31855433
API_HASH=941f5212e76bfd3fd77b50fd8ff3fb79
