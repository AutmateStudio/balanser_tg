# Секреты и локальная конфигурация (Правило Д — никогда в репозиторий)
.env
.env.*
!.env.example
*.env.local
n8n/n8n_api.txt

# WireGuard / VPN конфиги — содержат PrivateKey/PresharedKey (Правило Д).
# Инфраструктурные *.conf без секретов (напр. nginx snippets) — исключение ниже.
*.conf
!standalone_discovery/deploy/nginx/**/*.conf

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Сессии Telethon и локальные данные
*.session
*.session-journal
standalone_discovery/sessions/
standalone_discovery/data/
standalone_discovery/discovery_api/data/

# IDE / OS
.idea/
.vscode/
