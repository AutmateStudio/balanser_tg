# =============================================================================
# Lidogen Telegram Balancer — шаблон .env для dev-сервера vps-101
# =============================================================================
#
# Подготовка (один раз на ubuntu@vps-101):
#   cd ~/Lidogen_telegram_balancer
#   cp .env.example .env
#   nano .env                    # подставить пароль lead_monitor_owner
#
# Типовые команды:
#   docker compose build test
#   docker compose run --rm migrate
#   docker compose run --rm test              # полный pytest (~300+)
#   docker compose run --rm test python scripts/sync_accounts_to_pg.py
#   docker compose up -d queue-worker         # smoke воркера
#
# Хост без Docker:
#   set -a && source .env && set +a
#   bash scripts/run_all_tests.sh
#
# Не коммитьте .env. По SFTP на vps-101 не заливать .env с локальной машины.
#
# Discovery API (Telethon, VPN, D8 USE_PG_QUEUE) — отдельный файл:
#   standalone_discovery/.env  (из standalone_discovery/.env.example)
#
# Доступ к БД: Tailscale, docs(plan)/db-access-via-tailscale.md
# =============================================================================

# --- PostgreSQL (dev/staging на vps-100 через MagicDNS) ---
# Shared DB: очередь и платформа в одной БД lead_monitor.
# На vps-101 в Docker test/migrate используется network_mode: host — хост vps-100 доступен.

DATABASE_URL=postgresql://lead_monitor_owner:REPLACE_WITH_REAL_PASSWORD@vps-100:5432/lead_monitor
QUEUE_DATABASE_URL=postgresql://lead_monitor_owner:REPLACE_WITH_REAL_PASSWORD@vps-100:5432/lead_monitor

# --- Миграции (docker compose run --rm migrate) ---
MIGRATE_MODE=auto

# --- Pytest: integration-тесты и изоляция от queue-worker ---
# Без QUEUE_DATABASE_URL integration-тесты пропускаются.
PYTEST_TEST_PRIORITY=2000000000

# --- Queue worker (docker compose up -d queue-worker) ---
LOG_LEVEL=INFO
WORKER_TASK_ADAPTER=mock

# Опционально: фиксированный worker_id в логах (по умолчанию hostname:pid)
WORKER_ID=

# Ограничить типы задач (пусто = все enabled). Пример: parser_add_channel
WORKER_TASK_TYPES=

WORKER_POLL_INTERVAL_SECONDS=1.0
WORKER_LOCK_TTL_SECONDS=300
WORKER_RETRY_DELAY_SECONDS=60
WORKER_POSTPONE_DELAY_SECONDS=300
WORKER_WATCHDOG_ENABLED=true
WORKER_WATCHDOG_INTERVAL_SECONDS=30

# --- G5: watchdog auto-retry stuck (queue-worker, default off в prod) ---
WATCHDOG_AUTO_RETRY_ENABLED=false
WATCHDOG_AUTO_RETRY_MAX_ATTEMPTS=2
WATCHDOG_AUTO_RETRY_DELAY_SECONDS=60

# --- G4: мониторинг и алерты (docker compose --profile monitoring up -d queue-monitor) ---
MONITOR_INTERVAL_SECONDS=120
ALERT_ENABLED=true
ALERT_WEBHOOK_URL=
ALERT_COOLDOWN_SECONDS=1800
ALERT_QUEUE_GROWTH_PERCENT=20
ALERT_QUEUE_GROWTH_WINDOW_SECONDS=900
ALERT_OLDEST_QUEUED_MAX_SECONDS=3600
ALERT_HIGH_POSTPONE_MIN=10
ALERT_ERROR_RATE_MIN_PERCENT=50
ALERT_ERROR_RATE_MIN_ATTEMPTS=5

# --- G7: пороги загрузки каналов и ресурса (Telegram dev-чат) ---
THRESHOLD_ALERT_ENABLED=true
THRESHOLD_CHANNEL_PERCENT=75
THRESHOLD_RESOURCE_PERCENT=0
MAX_CHANNELS_PER_SESSION=500
DEV_ALERT_TELEGRAM_CHAT_ID=
# BOT_TOKEN=  # или TELEGRAM_BOT_TOKEN — тот же бот, что в discovery

# --- G6: детектор повторяющихся ошибок (queue-monitor subcommand detector / all) ---
ERROR_DETECTOR_ENABLED=true
ERROR_DETECTOR_WINDOW_SECONDS=3600
ERROR_DETECTOR_MIN_COUNT=5
ERROR_DETECTOR_RPH_FACTOR=0.7
ERROR_DETECTOR_MIN_RPH=2
ERROR_DETECTOR_REPEAT_WINDOW_SECONDS=86400
ERROR_DETECTOR_COOLDOWN_SECONDS=3600

# --- Docker queue-worker: bind mount Telethon *.session на хосте ---
# Обязательно ./ или / — без префикса Compose воспринимает значение как имя volume.
HOST_SESSIONS_DIR=./standalone_discovery/sessions

# --- A10: sync_accounts_to_pg.py (пути от корня репозитория, хост или контейнер test) ---
ACCOUNT_STORE_PATH=standalone_discovery/discovery_api/data/telegram_accounts.db
PARSER_STORE_PATH=standalone_discovery/discovery_api/data/parser_jobs.json
SESSIONS_DIR=standalone_discovery/sessions

# --- Telethon (обязательно при WORKER_TASK_ADAPTER=clump) ---
# Скопировать из standalone_discovery/.env (не коммитить сюда реальные значения).
# API_ID=
# API_HASH=

# --- D12 E2E staging — docs(plan)/D12-тестирование.md, scripts/e2e_d12/env.d12.example ---

# =============================================================================
# Локальная разработка без Tailscale (profile local, Windows/Linux)
# =============================================================================
# docker compose --profile local up -d postgres
# docker compose --profile local run --rm migrate-local
# docker compose --profile local run --rm test-local
#
# QUEUE_DATABASE_URL=postgresql://lead_monitor_owner:dev_password@localhost:5433/lead_monitor
# PG_LOCAL_PORT=5433
