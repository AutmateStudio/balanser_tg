API_ID=31855433
API_HASH=941f5212e76bfd3fd77b50fd8ff3fb79
API_KEY=changeme
WEBHOOK_API_KEY=changeme
START_WEBHOOK_URL=https://example.com/telegram/start
DISCOVERY_MIN_CHANNEL_SCORE_RATIO=0.5
MAX_CHANNELS_PER_SESSION=500

# D8 — async add-channels → PostgreSQL task_queue (вместо SQLite action_queue).
# Для D12 staging: true + QUEUE_DATABASE_URL + image Dockerfile.pg-queue.
USE_PG_QUEUE=false

# DSN очереди (Tailscale → vps-100). Тот же DSN на vps-101 queue-worker.
# В network_mode: service:vpn используйте Tailscale IP vps-100 (имя не резолвится).
# QUEUE_DATABASE_URL=postgresql://lead_monitor_owner:PASSWORD@vps-100:5432/lead_monitor

# D12 Вариант A — крутить queue-worker в процессе discovery (общий in-memory clump).
# Требует USE_PG_QUEUE=true и WORKER_TASK_ADAPTER=clump.
# Co-located prod (vps-104): DISCOVERY_INPROCESS_WORKER=true, отдельный queue-worker не запускать.
DISCOVERY_INPROCESS_WORKER=false
# WORKER_TASK_ADAPTER=clump

# Сколько параллельных worker'ов запустить при DISCOVERY_INPROCESS_WORKER=true.
# Рекомендуется = числу active-аккаунтов в clump (один worker = один аккаунт единовременно).
# PG (FOR UPDATE SKIP LOCKED + pick_and_reserve) не даёт двум воркерам взять одно и то же.
# INPROCESS_WORKER_COUNT=4

# C5 — порог min_available_resource_percent (override значения из task_types).
# Целое 0..100; пусто/невалидное → берётся значение из БД (seed = 80 для parser_add_channel).
# Низкий rph_limit в seed + порог 80% дают ~1 операцию/час на аккаунт; для staging/E2E
# можно снизить, напр. 50, чтобы лимитер не блокировал повторные прогоны.
# RESOURCE_MIN_AVAILABLE_PERCENT=50
